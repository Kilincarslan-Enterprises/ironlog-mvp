{
  "name": "ironlog-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "pages:dev": "wrangler pages dev --d1 DB=ironlog-mvp-db -- npm run dev",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 migrations apply ironlog-mvp-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ironlog-mvp-db --remote",
    "db:generate": "drizzle-kit generate",
    "token:create": "node scripts/create-agent-token.mjs"
  },
  "dependencies": {
    "@clerk/backend": "^3.10.0",
    "@clerk/clerk-react": "^5.61.8",
    "@hono/clerk-auth": "^3.1.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.107.0"
  }
}
